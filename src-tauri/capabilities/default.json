{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:path:default",
    "core:event:default",
    {
      "identifier": "dialog:allow-save",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Users/**"
        },
        {
          "path": "C:\\Users\\**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Users/**"
        },
        {
          "path": "C:\\Users\\**"
        }
      ]
    }
  ]
}