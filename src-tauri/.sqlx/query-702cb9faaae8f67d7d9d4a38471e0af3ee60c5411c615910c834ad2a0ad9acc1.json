{
  "db_name": "SQLite",
  "query": "\n        SELECT \n            e.id,\n            e.nom,\n            e.prenom,\n            e.telephone,\n            e.titre,\n            e.statut,\n            e.volume_horaire_max,\n            COALESCE(SUM(v.vht), 0.0) as heures_consommees,\n            (e.volume_horaire_max - COALESCE(SUM(v.vht), 0.0)) as heures_restantes,\n            b.designation as banque_designation,\n            e.numero_compte,\n            e.cle_rib\n        FROM enseignants e\n        LEFT JOIN banques b ON b.id = e.banque_id\n        LEFT JOIN vacations v ON v.enseignant_id = e.id AND v.annee_scolaire = ?\n        GROUP BY e.id\n        ORDER BY e.nom, e.prenom\n        ",
