  "query": "\n        SELECT \n            e.id,\n            e.nom,\n            e.prenom,\n            e.telephone,\n            e.titre,\n            e.statut,\n            e.volume_horaire_max,\n            e.banque_id,\n            e.numero_compte,\n            e.cle_rib,\n            b.designation as banque_designation\n        FROM enseignants e\n        LEFT JOIN banques b ON b.id = e.banque_id\n        WHERE e.titre = ?\n        ORDER BY e.nom, e.prenom\n        ",
